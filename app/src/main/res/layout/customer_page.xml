<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/main">


    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="12dp">
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center"
            >
        <ImageButton
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@drawable/baseline_arrow_back_24"/>
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Takeaway orders"
            android:textColor="@color/white"
            android:textStyle="bold"
            android:textSize="18sp"
            />
    </LinearLayout>
        <ImageButton
            android:id="@+id/burger_special"
            android:layout_width="match_parent"
            android:layout_height="200dp"
            android:layout_marginTop="20dp"
            android:layout_marginBottom="10dp"

            android:background="@android:color/transparent"
            android:contentDescription="@string/todo"
            android:padding="3dp"

            android:scaleType="centerCrop"
            android:src="@drawable/burger_sp"
            app:srcCompat="@drawable/burger_sp" />

            <EditText
                android:layout_width="match_parent"
                android:layout_height="40dp"
                android:autofillHints="search"

                android:inputType="textFilter"
                android:text="@string/search"
                android:textColor="@color/white"

                android:padding="10dp"
                android:textSize="17sp"
                android:paddingStart="12dp"

                android:paddingEnd="12dp"
                android:background="@drawable/catagories"
                />

        <HorizontalScrollView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:layout_marginBottom="10dp"
            android:scrollbars="none">

            <LinearLayout
                style="?android:attr/buttonBarStyle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
            >

                <Button
                    style="?android:attr/buttonBarButtonStyle"
                    android:layout_width="wrap_content"
                    android:layout_height="40dp"
                    android:background="@drawable/catagory_btn"
                    android:text="@string/frequent_order"
                    android:textColor="@color/white"
                    android:textSize="12sp" />

                <Button
                    style="?android:attr/buttonBarButtonStyle"
                    android:layout_width="wrap_content"
                    android:layout_height="40dp"
                    android:background="@drawable/catagory_btn"
                    android:text="@string/pizza"
                    android:textColor="@color/white"
                    android:textSize="12sp" />

                <Button
                    style="?android:attr/buttonBarButtonStyle"
                    android:layout_width="wrap_content"
                    android:layout_height="40dp"
                    android:background="@drawable/catagory_btn"
                    android:text="@string/burgers"
                    android:textColor="@color/white"
                    android:textSize="12sp" />

                <Button
                    style="?android:attr/buttonBarButtonStyle"
                    android:layout_width="wrap_content"
                    android:layout_height="40dp"
                    android:background="@drawable/catagory_btn"
                    android:text="@string/drinks"
                    android:textColor="@color/white"
                    android:textSize="12sp" />

                <Button
                    style="?android:attr/buttonBarButtonStyle"
                    android:layout_width="wrap_content"
                    android:layout_height="40dp"
                    android:background="@drawable/catagory_btn"
                    android:text="@string/dessert"
                    android:textColor="@color/white"
                    android:textSize="12sp" />

            </LinearLayout>
        </HorizontalScrollView>
        <!--Products-->

        <LinearLayout
            android:id="@+id/burger_container"
            android:layout_width="match_parent"
            android:layout_height="120dp"
            android:padding="12dp"
            android:layout_marginBottom="10dp"
            android:orientation="horizontal"
            android:visibility="visible"
            android:background="@drawable/catagories"
        >
            <ImageView
                android:layout_width="100dp"
                android:layout_height="match_parent"
                android:scaleType="centerCrop"
                android:src="@drawable/spicy_burger"
                android:background="@drawable/product_bg" />
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:orientation="vertical"
                android:layout_marginStart="16dp"
                android:gravity="center_vertical"
            >
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/spicy_beef_burger"
                    android:textColor="@color/white"
                    android:textStyle="bold"
                    android:paddingStart="13dp"
                    android:paddingEnd="13dp"
                />
                <Space
                    android:layout_width="8dp"
                    android:layout_height="12dp" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/r14_99"
                    android:textColor="@color/white"
                    android:textStyle="bold"
                    android:paddingStart="13dp"
                    android:paddingEnd="13dp"
                />

            </LinearLayout>
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="120dp"
            android:padding="12dp"
            android:layout_marginBottom="10dp"
            android:orientation="horizontal"
            android:background="@drawable/catagories">
            <ImageView
                android:layout_width="100dp"
                android:layout_height="match_parent"
                android:scaleType="centerCrop"
                android:src="@drawable/chicken_burger" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:orientation="vertical"
                android:layout_marginStart="16dp"
                android:gravity="center_vertical">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/juicy_chicken_burger"
                    android:textColor="@color/white"
                    android:textStyle="bold"
                    android:paddingStart="13dp"
                    android:paddingEnd="13dp"
                />
                <Space
                    android:layout_width="8dp"
                    android:layout_height="12dp" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/r24_99"
                    android:textColor="@color/white"
                    android:paddingStart="13dp"
                    android:paddingEnd="13dp"
                    android:textStyle="bold"
                />
            </LinearLayout>
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="120dp"
            android:padding="12dp"
            android:layout_marginBottom="10dp"
            android:orientation="horizontal"
            android:background="@drawable/catagories"
        >
            <ImageView
                android:layout_width="100dp"
                android:layout_height="match_parent"
                android:scaleType="centerCrop"
                android:src="@drawable/classic_burger" />
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:orientation="vertical"
                android:layout_marginStart="16dp"
                android:gravity="center_vertical">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="@color/white"
                    android:text="@string/_2_double_beef_burger"
                    android:textStyle="bold"
                    android:paddingStart="13dp"
                    android:paddingEnd="13dp"
                />
                <Space
                    android:layout_width="8dp"
                    android:layout_height="12dp" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/r39_99"
                    android:textColor="@color/white"
                    android:textStyle="bold"
                    android:paddingStart="13dp"
                    android:paddingEnd="13dp"
                />
            </LinearLayout>
        </LinearLayout>
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="120dp"
            android:padding="12dp"
            android:layout_marginBottom="10dp"
            android:orientation="horizontal"
            android:background="@drawable/catagories"
        >
            <ImageView
                android:layout_width="100dp"
                android:layout_height="match_parent"
                android:scaleType="centerCrop"
                android:src="@drawable/black_burger" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:orientation="vertical"
                android:layout_marginStart="16dp"
                android:gravity="center_vertical">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/black_spicy_burger"
                    android:textColor="@color/white"
                    android:textStyle="bold"
                    android:paddingStart="13dp"
                    android:paddingEnd="13dp"
                />
                <Space
                    android:layout_width="8dp"
                    android:layout_height="12dp" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/r17_99"
                    android:textColor="@color/white"
                    android:textStyle="bold"
                    android:paddingStart="13dp"
                    android:paddingEnd="13dp"
                />

            </LinearLayout>
        </LinearLayout>

    </LinearLayout>
</ScrollView>