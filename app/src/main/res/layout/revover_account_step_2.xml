<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:orientation="vertical"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/main"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    >
    <Space
        android:layout_width="match_parent"
        android:layout_height="10dp"/>
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Security Check"
        android:textColor="@color/white"
        android:textSize="30sp"
        android:textStyle="bold"
        android:paddingStart="15dp"
        android:paddingEnd="15dp"
        android:fontFamily="@font/archivoblack"

        />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Please answer your secret question."
        android:textColor="@color/white"
        android:textSize="16sp"
        android:textStyle="bold"
        android:paddingStart="15dp"
        android:layout_marginTop="10dp"/>

    <Space
        android:layout_width="wrap_content"
        android:layout_height="50dp"/>

    <LinearLayout
        android:layout_width="350dp"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        android:layout_marginStart="25dp"
        android:background="@drawable/catagories"
        >

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginTop="20sp"
            >

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="YOUR QUESTION"
                android:textColor="@color/white"
                android:textStyle="bold"
                android:textSize="15sp"
                android:paddingStart="10dp"
                />

            <EditText
                android:id="@+id/choose_question"
                android:layout_width="310dp"
                android:layout_height="wrap_content"

                android:textStyle="bold"
                android:hint="How much money is in your bank account?"

                android:textSize="15sp"
                android:inputType="textPersonName"
                android:background="@drawable/edittext_bg"

                android:padding="@dimen/padding_standard"
                android:textColor="@color/white"
                android:textColorHint="#FFFF"

                android:layout_marginTop="5dp"
                android:drawablePadding="@dimen/drawable_padding"
                />
        </LinearLayout>


        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginTop="20sp"
            >

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="YOUR ANSWER"
                android:textColor="@color/white"
                android:textStyle="bold"
                android:textSize="15sp"
                android:paddingStart="10dp"
                />

            <EditText
                android:id="@+id/secret_answer"
                android:layout_width="310dp"
                android:layout_height="wrap_content"

                android:textStyle="bold"
                android:hint="Type your answer here..."

                android:textSize="15sp"
                android:inputType="text"
                android:background="@drawable/edittext_bg"

                android:padding="@dimen/padding_standard"
                android:textColor="@color/white"
                android:textColorHint="@color/glass_white"

                android:layout_marginTop="5dp"
                android:drawablePadding="@dimen/drawable_padding"
                />
        </LinearLayout>

        <Space
            android:layout_width="match_parent"
            android:layout_height="30dp"/>

        <Button
            android:id="@+id/verify_answer"
            android:layout_width="310dp"
            android:layout_height="wrap_content"
            android:text="VERIFY ANSWER"
            android:textColor="@color/black"
            android:textStyle="bold"
            android:textSize="20dp"
            android:background="@drawable/btn_gradient_bg"
            app:backgroundTint="@null"
            android:layout_marginBottom="30dp"
            />
    </LinearLayout>
    <Space
        android:layout_width="match_parent"
        android:layout_height="40dp"/>
    <Button
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="GO BACK"
        android:textSize="20dp"
        android:textStyle="bold"
        android:layout_marginStart="125dp"
        android:textColor="@color/white"
        android:background="@drawable/white_border_bg"
        app:backgroundTint="@null"/>
</LinearLayout>