<?xml version="1.0" encoding="utf-8"?>
<!-- 
    Staff New Order Assignment Screen (s_assign_order.xml)
    Allows staff members to enter a customer's email address and select an assigned restaurant
    to initialize a new order card for the active preparation queue.
-->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:orientation="vertical"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/main">

    <!-- ScrollView guarantees full access to inputs on smaller or rotated screens -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <!-- Title Header section with back navigation button -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginTop="10dp"
                android:layout_marginBottom="30dp">

                <!-- Back button to return to the active takeaway queue -->
                <ImageButton
                    android:id="@+id/back_btn"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:src="@drawable/baseline_arrow_back_24"
                    android:background="@drawable/no_backround"
                    android:contentDescription="Back" />

                <!-- Screen main title -->
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="New Order"
                    android:textColor="@color/white"
                    android:layout_marginStart="15dp"
                    android:textStyle="bold"
                    android:textSize="25sp" />
            </LinearLayout>

            <!-- Instructive helper label -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Enter the customer's email to link order"
                android:textColor="@color/white"
                android:textSize="15sp"
                android:paddingStart="10dp" />

            <Space
                android:layout_width="match_parent"
                android:layout_height="20dp" />

            <!-- Input fields group container featuring rounded borders card style -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/categories"
                android:padding="20dp"
                android:layout_marginHorizontal="10dp">

                <!-- Input section 1: Customer Email lookup -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Customer Email"
                    android:textColor="@color/white"
                    android:textStyle="bold"
                    android:textSize="15sp" />

                <EditText
                    android:id="@+id/fullname_edit_text"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:drawableTint="#FFFF"
                    android:hint="@string/eg_guest_gmail_com"
                    android:textSize="15sp"
                    android:inputType="textEmailAddress"
                    android:background="@drawable/edittext_bg"
                    android:padding="@dimen/padding_standard"
                    android:textColor="@color/white"
                    android:textColorHint="#FFFF"
                    android:layout_marginTop="5dp"
                    android:drawablePadding="@dimen/drawable_padding" />

                <!-- Input section 2: Assigned Restaurant picker -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Assigned Restaurant"
                    android:textColor="@color/white"
                    android:textStyle="bold"
                    android:textSize="15sp"
                    android:layout_marginTop="20dp" />

                <EditText
                    android:id="@+id/selected_restaurant"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textStyle="bold"
                    android:drawableTint="#FFFF"
                    android:hint="Casa Nova"
                    android:textSize="15sp"
                    android:inputType="text"
                    android:background="@drawable/edittext_bg"
                    android:padding="@dimen/padding_standard"
                    android:textColor="@color/white"
                    android:textColorHint="#FFFF"
                    android:layout_marginTop="5dp"
                    android:layout_marginBottom="10dp"
                    android:drawablePadding="@dimen/drawable_padding" />
            </LinearLayout>

            <Space
                android:layout_width="match_parent"
                android:layout_height="30dp" />

            <!-- Action button: Initialize order card -->
            <Button
                android:id="@+id/send_to_customer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="30dp"
                android:text="@string/initialize_order"
                android:textColor="@color/black"
                android:textStyle="bold"
                android:layout_marginBottom="10dp"
                android:background="@drawable/btn_gradient_bg"
                app:backgroundTint="@null" />

            <!-- Action button: Cancel layout screen and return -->
            <Button
                android:id="@+id/staff_cancel_order"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="30dp"
                android:text="Cancel"
                android:textColor="@color/white"
                android:textStyle="bold"
                android:background="@drawable/categories"
                app:backgroundTint="@null" />
        </LinearLayout>
    </ScrollView>
</LinearLayout>