<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:orientation="vertical"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/main">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp"
            android:gravity="center_horizontal">

            <!-- Satisfaction Circle -->
            <LinearLayout
                android:layout_width="160dp"
                android:layout_height="160dp"
                android:orientation="vertical"
                android:gravity="center"
                android:layout_marginTop="30dp"
                android:background="@drawable/round_shape">

                <TextView
                    android:id="@+id/average_rate_for_staff"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="100%"
                    android:textColor="@color/green"
                    android:textSize="35sp"
                    android:textStyle="bold"
                    android:fontFamily="@font/archivoblack" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="5dp"
                    android:text="SATISFACTION"
                    android:textStyle="bold"
                    android:fontFamily="@font/archivoblack"
                    android:textColor="@color/white"
                    android:textSize="14sp" />
            </LinearLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="30dp"
                android:text="Staff Profile"
                android:textColor="@color/white"
                android:textSize="35sp"
                android:textStyle="bold"
                android:fontFamily="@font/archivoblack"
                android:gravity="center" />

            <Space
                android:layout_width="match_parent"
                android:layout_height="10dp" />
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center"
                android:layout_gravity="center_horizontal">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text=" Assigned: "
                    android:drawableStart="@drawable/online_dot"
                    android:textColor="@color/white"
                    android:textSize="15sp"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="@color/white"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:text="restaurant"

                    />
            </LinearLayout>

              <Space
                  android:layout_width="match_parent"
                  android:layout_height="30dp"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/categories"
            android:gravity="center"
            android:orientation="vertical"
            android:layout_marginVertical="10dp"
            >
            <Space
                android:layout_width="match_parent"
                android:layout_height="15dp"/>

            <android.widget.Button
                android:id="@+id/staff_view_history"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="20dp"
                android:layout_marginTop="20dp"
                android:padding="16dp"
                android:background="@drawable/white_border_bg"
                android:text="Order History"
                android:textColor="@color/white"
                android:textStyle="bold"
                android:textSize="18sp"
                android:drawableStart="@drawable/order_history"
                android:drawablePadding="15dp"
                />
            <Space
                android:layout_width="match_parent"
                android:layout_height="20dp"/>
            <android.widget.Button
                android:id="@+id/staff_logout"
                android:layout_width="match_parent"
                android:background="@drawable/white_border_bg"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="20dp"
                android:padding="16dp"
                android:text="Logout"
                android:textSize="18sp"
                app:backgroundTint="@null"
                android:textColor="@color/white"
                android:textStyle="bold"
                android:drawableStart="@drawable/logout"
                android:drawablePadding="15dp"/>
            <Space
                android:layout_width="match_parent"
                android:layout_height="20dp"/>
            <android.widget.Button
                android:id="@+id/staff_view_feedback"
                android:layout_width="match_parent"
                android:background="@drawable/white_border_bg"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="20dp"
                android:padding="16dp"
                android:text="Performance Feedback"
                app:backgroundTint="@null"
                android:textSize="18sp"
                android:textColor="@color/white"
                android:textStyle="bold"
                android:drawableStart="@drawable/feedback"
                android:drawablePadding="15dp"/>
            <Space
                android:layout_width="match_parent"
                android:layout_height="20dp"/>
        </LinearLayout>

            <!-- Feedback Card -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/green_border_bg"
                android:padding="20dp"
                android:visibility="gone"
                android:layout_marginHorizontal="10dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <TextView
                        android:id="@+id/status"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="ORDER #101"
                        android:textColor="@color/white"
                        android:textStyle="bold"
                        android:textSize="14sp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="EXCEPTIONAL"
                        android:textStyle="bold"
                        android:textColor="@color/green"
                        android:textSize="12sp" />
                </LinearLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:text="Excellent Service"
                    android:textColor="@color/white"
                    android:textSize="18sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <android.widget.Button
                android:id="@+id/back_to_queue_btn"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="10dp"
                android:layout_marginTop="30dp"
                android:layout_marginHorizontal="30dp"
                android:text="BACK TO QUEUE"
                android:textStyle="bold"
                android:textSize="20sp"
                android:textColor="@color/black"
                android:background="@drawable/btn_gradient_bg"
                 />
        </LinearLayout>
    </ScrollView>
</LinearLayout>