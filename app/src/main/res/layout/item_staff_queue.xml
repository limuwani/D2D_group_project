<?xml version="1.0" encoding="utf-8"?>
<!-- 
    Staff Active Takeaway Queue Item Card Layout (item_staff_queue.xml)
    Renders an individual order card inside the staff active preparation list.
    Displays Order ID, preparation status badge, assigned customer name,
    and actions to transition the order through "READY" and "COLLECTED" phases.
-->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:orientation="vertical"
    android:padding="20dp"
    android:layout_marginHorizontal="10dp"
    android:layout_marginVertical="8dp"
    android:background="@drawable/white_border_bg">

    <!-- Header section holding Order ID and status badge -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <!-- Display the order identifier (e.g. ORDER #101) -->
        <TextView
            android:id="@+id/queue_order_id_text"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="ORDER #101"
            android:textColor="@color/white"
            android:textStyle="bold"
            android:textSize="18sp" />

        <!-- Interactive glass-morphism status badge (e.g. PENDING, PREPARING, READY) -->
        <TextView
            android:id="@+id/queue_order_status_text"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="PREPARING"
            android:textColor="@color/white"
            android:textStyle="bold"
            android:textSize="14sp"
            android:background="@drawable/glass_red"
            android:paddingHorizontal="12dp"
            android:paddingVertical="6dp"/>
    </LinearLayout>

    <Space
        android:layout_width="match_parent"
        android:layout_height="10dp" />

    <!-- Label displaying the linked customer's name and ID -->
    <TextView
        android:id="@+id/queue_customer_name_text"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Customer: Naledi | ID: 501"
        android:textColor="@color/white"
        android:textSize="16sp" />

    <Space
        android:layout_width="match_parent"
        android:layout_height="15dp" />

    <!-- Action buttons row: MARK READY and MARK COLLECTED -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center">

        <!-- Action Button: Mark the order status as "READY" for pickup -->
        <Button
            android:id="@+id/queue_mark_ready_btn"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="READY"
            android:textColor="@color/white"
            android:textStyle="bold"
            app:backgroundTint="@null"
            android:background="@drawable/green_border_bg"
            android:layout_marginEnd="5dp"/>

        <!-- Action Button: Mark the order status as "COLLECTED" (removes card from active list) -->
        <Button
            android:id="@+id/queue_mark_collected_btn"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="COLLECTED"
            android:textColor="@color/white"
            android:textStyle="bold"
            app:backgroundTint="@null"
            android:background="@drawable/red_border_bg"
            android:layout_marginStart="5dp"/>
    </LinearLayout>

</LinearLayout>
