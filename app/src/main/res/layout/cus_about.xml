<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/main_main"
    android:fitsSystemWindows="true"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="About D2D"
            android:fontFamily="@font/archivoblack"
            android:textColor="@color/white"
            android:textStyle="bold"
            android:textSize="30sp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:text="The next generation of ordering."
            android:textColor="@color/white" />

        <Space
            android:layout_width="wrap_content"
            android:layout_height="20dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/categories"
            android:padding="20dp"
            android:layout_marginHorizontal="10dp"
            android:orientation="vertical">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text=" OUR MISSION"
                android:textColor="@color/white"
                android:textStyle="bold"
                android:textSize="15sp"
                android:drawableStart="@drawable/target"
                />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/white"
                android:text="D2D serves as an intelligent bridge empowering companies to seamlessly host and manage their takeaway operations. We provide a state-of-the-art orchestration platform that hosts restaurant nodes, ensuring absolute clarity and efficiency from the moment an order is placed to the moment it is fulfilled."
                android:textSize="13sp"
                android:padding="16dp"
                />
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center"
                android:layout_gravity="center_horizontal">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:padding="5dp"
                    android:text="SEAMLESS"
                    android:textColor="@color/green"
                    android:textStyle="bold"
                    android:background="@drawable/green_border_bg"
                    />
                <Space
                    android:layout_width="10dp"
                    android:layout_height="wrap_content"/>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:padding="5dp"
                    android:text="EFFICIENT"
                    android:textColor="@color/red_dark"
                    android:textStyle="bold"
                    android:background="@drawable/red_border_bg"
                    />

            </LinearLayout>
        </LinearLayout>


        <Space
            android:layout_width="wrap_content"
            android:layout_height="20dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/categories"
            android:padding="20dp"
            android:layout_marginHorizontal="10dp"
            android:orientation="vertical">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text=" FOR CUSTOMERS"
                android:textColor="@color/white"
                android:textStyle="bold"
                android:textSize="15sp"
                android:drawableStart="@drawable/cus_person"
                />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/white"
                android:text="Experience a completely redefined ordering process."
                android:textSize="13sp"
                android:padding="16dp"
                />

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center"
                    android:layout_gravity="center_horizontal">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:padding="8dp"
                        android:text="Real-Time Tracking"
                        android:textColor="@color/white"
                        android:textStyle="bold"
                        android:background="@drawable/categories"
                        />
                    <Space
                        android:layout_width="10dp"
                        android:layout_height="wrap_content"/>
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:padding="8dp"
                        android:text="Order History"
                        android:textColor="@color/white"
                        android:textStyle="bold"
                        android:background="@drawable/categories"
                        />

                </LinearLayout>
                <Space
                    android:layout_width="wrap_content"
                    android:layout_height="10dp" />

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center"
                    android:layout_gravity="center_horizontal">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:padding="8dp"
                        android:text="Service Feedback"
                        android:textColor="@color/white"
                        android:textStyle="bold"
                        android:background="@drawable/categories"
                        />
                    <Space
                        android:layout_width="10dp"
                        android:layout_height="wrap_content"/>
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:padding="8dp"
                        android:text="Secure Profile"
                        android:textColor="@color/white"
                        android:textStyle="bold"
                        android:background="@drawable/categories"
                        />
                </LinearLayout>
        </LinearLayout>

        <Space
            android:layout_width="wrap_content"
            android:layout_height="20dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/categories"
            android:padding="20dp"
            android:layout_marginHorizontal="10dp"
            android:orientation="vertical">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text=" CORE ARCHITECTS"
                android:textColor="@color/white"
                android:textStyle="bold"
                android:textSize="15sp"
                android:drawableStart="@drawable/group"
                />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/white"
                android:text="The intelligence and architecture of the D2D platform were engineered by a dedicated team of visionaries."
                android:textSize="13sp"
                android:padding="10dp"
                />
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_gravity="left"
                >

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center"
                    android:layout_gravity="center_horizontal">
                    <ImageView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:src="@drawable/l"
                        android:padding="8dp"
                        android:background="@drawable/categories"
                        />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="   Limuwani"
                        android:textColor="@color/white"
                        android:fontFamily="@font/archivoblack" />

                </LinearLayout>
                <Space
                    android:layout_width="wrap_content"
                    android:layout_height="10dp" />
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center"
                    android:layout_gravity="center_horizontal">
                    <ImageView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:src="@drawable/t"
                        android:padding="8dp"
                        android:background="@drawable/categories"
                        />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="  Tahbiseng"
                        android:textColor="@color/white"
                        android:fontFamily="@font/archivoblack" />

                </LinearLayout>
                <Space
                    android:layout_width="wrap_content"
                    android:layout_height="10dp" />
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center"
                    android:layout_gravity="center_horizontal">
                    <ImageView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:src="@drawable/s"
                        android:padding="8dp"
                        android:background="@drawable/categories"
                        />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="  Sphephelo"
                        android:textColor="@color/white"
                        android:fontFamily="@font/archivoblack" />

                </LinearLayout>
            </LinearLayout>
        </LinearLayout>

        <Space
            android:layout_width="wrap_content"
            android:layout_height="20dp" />


        <Button
            android:id="@+id/terms_to_login"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:layout_marginHorizontal="20dp"
            android:text="BACK TO PROFILE"
            android:padding="10dp"
            android:textColor="@color/white"
            android:background="@drawable/white_border_bg"
            app:backgroundTint="@null" />

        <Space
            android:layout_width="match_parent"
            android:layout_height="30dp" />
    </LinearLayout>
</ScrollView>